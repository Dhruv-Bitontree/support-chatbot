# ==============================================
# LLM Provider Configuration
# ==============================================
# Choose your LLM provider: gemini, openai, or anthropic
LLM_PROVIDER=gemini

# API Keys (provide the key for your chosen provider)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override default model for your provider
# Defaults: gemini-2.0-flash, gpt-4o-mini, claude-sonnet-4-20250514
LLM_MODEL=

# LLM Parameters
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ==============================================
# Vector Store Configuration
# ==============================================
# Choose your vector store: faiss (local) or pinecone (cloud)
VECTOR_STORE_PROVIDER=faiss

# FAISS Configuration (local storage)
FAISS_INDEX_PATH=data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Pinecone Configuration (cloud storage)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=support-chatbot

# ==============================================
# Database Configuration
# ==============================================
DATABASE_URL=sqlite+aiosqlite:///./support.db

# ==============================================
# Server Configuration
# ==============================================
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
LOG_LEVEL=info

# ==============================================
# Sentiment Analysis Configuration
# ==============================================
# Threshold for escalating complaints (very negative)
SENTIMENT_ESCALATION_THRESHOLD=-0.5
# Threshold for detecting negative sentiment
SENTIMENT_NEGATIVE_THRESHOLD=-0.2

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_PER_MINUTE=30
