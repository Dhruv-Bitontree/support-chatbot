# ============================================
# Customer Support Chatbot - Environment Config
# ============================================
# Copy this file to .env and fill in your values

# --- LLM Provider ---
# Options: gemini (default), openai, anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
# Override default model (optional, leave empty for provider default)
LLM_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# --- Vector Store ---
# Options: faiss (default), pinecone
VECTOR_STORE_PROVIDER=faiss
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=support-chatbot
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/faiss_index

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./support.db

# --- Server ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
LOG_LEVEL=info

# --- Sentiment Thresholds ---
SENTIMENT_ESCALATION_THRESHOLD=-0.5
SENTIMENT_NEGATIVE_THRESHOLD=-0.2

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/chat/ws
